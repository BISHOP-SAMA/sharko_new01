# ================================
# Deployer Wallet (Hardhat / Foundry / Scripts)
# ================================
PRIVATE_KEY=your_private_key_here

# ================================
# RPC URLs
# ================================
# Base Mainnet (recommended for production)
BASE_MAINNET_RPC=https://mainnet.base.org

# Optional: Alchemy RPC (faster & more reliable than public RPC)
# Replace with your actual Alchemy endpoint from the dashboard
# Example: https://base-mainnet.g.alchemy.com/v2/_joVDSh3maW9UOeh67ww4...
BASE_MAINNET_ALCHEMY_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY_HERE

# Base Sepolia (keep for testing if needed)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# ================================
# Contract Addresses (Mainnet)
# ================================
SHACKO_NFT_ADDRESS=0x7f30f4b6d5C98D29E32cf013558A01443c87C013
STAKING_CONTRACT_ADDRESS=0xCb5EA03fdEF2FfC793d2fF4811477f3c20d4Fda5
SHACK_TOKEN_ADDRESS=0x2FbCa943BbD81FCCeaedFAdbb324Bba51Fc6A2E3

# ================================
# Treasury (receives staking fees)
# ================================
TREASURY_WALLET_ADDRESS=0xc1e4c27A2E20EA7C6966F6945738171EEeEf5FC7

# ================================
# API Keys
# ================================
# Alchemy API Key (for frontend NFT fetching)
NEXT_PUBLIC_ALCHEMY_API_KEY=_joVDSh3maW9UOeh67ww4...   # ← Paste your full key here

# Basescan (for contract verification)
BASESCAN_API_KEY=

# ================================
# Optional: Other settings
# ================================
# NEXT_PUBLIC_SITE_URL=https://shacko.xyz